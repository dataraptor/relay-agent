# Relay — environment variables (copy to .env; never commit real keys).
# Split 01 writes no provider code, so no key is required to run its tests.
# These are consumed starting in Split 02 (Anthropic) and Split 05 (OpenAI).

# Anthropic — used by the default provider (Splits 02–04).
ANTHROPIC_API_KEY=

# OpenAI (Split 05). Use EITHER the standard OpenAI key OR the Azure OpenAI trio below.
# Standard OpenAI (api.openai.com):
OPENAI_API_KEY=

# Azure OpenAI (selected automatically when AZURE_OPENAI_ENDPOINT is set). The chat deployment
# name is the model id (this project pins gpt-5.5). OPENAI_API_VERSION defaults if unset.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2025-01-01-preview
